{
  "name": "@sphalerite-foundry/zinc-ts-sdk",
  "version": "1.142.0",
  "private": false,
  "type": "module",
  "license": "UNLICENSED",
  "description": "TypeScript SDK for the Zinc protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/sphalerite-foundry/zinc-ts-sdk.git"
  },
  "homepage": "https://github.com/sphalerite-foundry/zinc-ts-sdk#readme",
  "bugs": {
    "url": "https://github.com/sphalerite-foundry/zinc-ts-sdk/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./codama-ts": {
      "types": "./dist/codama-ts/index.d.ts",
      "import": "./dist/codama-ts/index.js",
      "require": "./dist/codama-ts/index.cjs"
    },
    "./codama-ts-custom": {
      "types": "./dist/codama-ts-custom/index.d.ts",
      "import": "./dist/codama-ts-custom/index.js",
      "require": "./dist/codama-ts-custom/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/codama-ts/index.ts src/codama-ts-custom/index.ts --format esm,cjs --dts --clean --sourcemap --inject src/shims/buffer.ts",
    "prepack": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "lint": "npm run lint:format",
    "prettier:check": "npm run lint:format",
    "hooks:pre-commit": "npm run lint && lint-staged",
    "hooks:pre-push": "npm run lint && npm run prettier:check && npm test && npm run build",
    "lint:format": "prettier \"src/**/*.ts\" \"*.json\" --check",
    "lint:fix": "prettier \"src/**/*.ts\" \"*.json\" -w --log-level warn",
    "prepare": "husky"
  },
  "dependencies": {
    "@arcium-hq/client": "0.10.2",
    "@solana/kit": "^6.8.0",
    "@solana/program-client-core": "^6.8.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.3",
    "buffer": "^6.0.3"
  },
  "lint-staged": {
    "src/**/*.ts": "prettier --write",
    "*.json": "prettier --write"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^24.12.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
